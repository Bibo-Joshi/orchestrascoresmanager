{
	"name": "nextcloud/orchestrascoresmanager",
	"description": "Organize your orchestras scores database directly within NextCloud",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "Hinrich Mahler",
			"email": "orchestra-scores-manager@mahlerhome.de",
			"homepage": "https://github.com/Bibo-Joshi"
		}
	],
	"autoload": {
		"psr-4": {
			"OCA\\OrchestraScoresManager\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\OrchestraScoresManager\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@composer bin all install --ansi"
		],
		"post-update-cmd": [
			"@composer bin all install --ansi"
		],
		"lint": "find . -name \\*.php -not -path './vendor/*' -not -path './vendor-bin/*' -not -path './build/*' -print0 | xargs -0 -n1 php -l",
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"psalm": "psalm --threads=1 --no-cache",
		"test:unit": "vendor-bin/phpunit/vendor/phpunit/phpunit/phpunit -c tests/phpunit.xml --colors=always --fail-on-warning --fail-on-risky",
		"openapi": "generate-spec --verbose",
		"rector": "rector && composer cs:fix"
	},
	"require": {
		"bamarni/composer-bin-plugin": "^1.8",
		"php": "^8.2"
	},
	"require-dev": {
		"nextcloud/ocp": "dev-stable32",
		"roave/security-advisories": "dev-latest"
	},
	"config": {
		"allow-plugins": {
			"bamarni/composer-bin-plugin": true
		},
		"optimize-autoloader": true,
		"sort-packages": true,
		"platform": {
			"php": "8.2"
		}
	}
}
